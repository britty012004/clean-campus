<%- include('partials/header') %>

    <main class="container" style="max-width: 800px; margin: 2rem auto;">
        <div class="card glass-morphism" style="padding: 2rem; border-radius: var(--radius-lg);">
            <h1 style="font-size: 2rem; margin-bottom: 1.5rem;">Report an Issue</h1>

            <% if (typeof error !=='undefined' && error) { %>
                <div
                    style="background: #fee2e2; color: #dc2626; padding: 0.75rem 1rem; border-radius: var(--radius-md); margin-bottom: 1.5rem; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem;">
                    <i class="fas fa-exclamation-circle"></i>
                    <%= error %>
                </div>
                <% } %>

                    <form action="/report" method="POST" enctype="multipart/form-data">
                        <div class="grid grid-cols-2">
                            <div class="form-group">
                                <label for="title">Issue Title</label>
                                <input type="text" id="title" name="title" class="form-control"
                                    placeholder="e.g., Broken Bench in S6 CSE" required>
                            </div>
                            <div class="form-group">
                                <label for="location">Location</label>
                                <input type="text" id="location" name="location" class="form-control"
                                    placeholder="e.g., classroom, Block A" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="description">Detailed Description</label>
                            <textarea id="description" name="description" class="form-control" rows="4"
                                placeholder="Mention details about the issue..." required></textarea>
                        </div>

                        <div class="form-group">
                            <label for="image">Upload Photo (Optional)</label>
                            <div
                                style="border: 2px dashed var(--border); padding: 1.5rem; border-radius: var(--radius-md); text-align: center; cursor: pointer;">
                                <i class="fas fa-camera"
                                    style="font-size: 2rem; color: var(--text-light); margin-bottom: 0.5rem;"></i>
                                <p style="color: var(--text-light);">Click to select or drag and drop a file</p>
                                <input type="file" id="image" name="image" class="form-control"
                                    style="opacity: 0; position: absolute; z-index: -1;">
                                <div id="preview" style="margin-top: 1rem; display: none;">
                                    <img id="preview-img" style="max-width: 200px; border-radius: var(--radius-md);">
                                </div>
                            </div>
                        </div>

                        <script>
                            const fileInput = document.getElementById('image');
                            const previewImg = document.getElementById('preview-img');
                            const previewDiv = document.getElementById('preview');
                            fileInput.parentElement.onclick = () => fileInput.click();
                            fileInput.onchange = (e) => {
                                const file = e.target.files[0];
                                if (file) {
                                    const reader = new FileReader();
                                    reader.onload = (e) => {
                                        previewImg.src = e.target.result;
                                        previewDiv.style.display = 'block';
                                    }
                                    reader.readAsDataURL(file);
                                }
                            }
                        </script>

                        <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                            <button type="submit" class="btn btn-primary" style="flex: 1; padding: 0.8rem;">Submit
                                Report</button>
                            <a href="/" class="btn btn-outline"
                                style="flex: 1; padding: 0.8rem; text-decoration: none;">Cancel</a>
                        </div>
                    </form>
        </div>
    </main>

    <%- include('partials/footer') %>